{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["global", "namespace", "applications", "postgresql", "redis", "kafka", "mqtt", "secrets"],
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "environment": { "type": "string", "minLength": 1 },
        "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "allowInlineValues": { "type": "boolean" },
        "existingSecretName": { "type": "string" }
      }
    },
    "postgresql": {
      "type": "object",
      "required": ["mode", "port"],
      "properties": {
        "mode": { "type": "string", "enum": ["local", "external"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sslMode": { "type": "string" },
        "external": {
          "type": "object",
          "properties": {
            "host": { "type": "string" }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "required": ["mode", "port"],
      "properties": {
        "mode": { "type": "string", "enum": ["local", "external"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "kafka": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["local", "external"] }
      }
    },
    "mqtt": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["local", "external"] }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["enabled", "host", "paths"],
            "properties": {
              "enabled": { "type": "boolean" },
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["path", "serviceName", "servicePort"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "serviceName": { "type": "string", "minLength": 1 },
                    "servicePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "networkPolicies": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultDenyIngress": { "type": "boolean" },
        "defaultDenyEgress": { "type": "boolean" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 1 },
        "runAsGroup": { "type": "integer", "minimum": 1 },
        "fsGroup": { "type": "integer", "minimum": 1 },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["RuntimeDefault", "Localhost", "Unconfined"] }
          }
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 1 },
        "runAsGroup": { "type": "integer", "minimum": 1 },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": { "type": "object" }
      }
    },
    "applications": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "name", "serviceName", "replicaCount", "containerPort", "image", "service"],
        "properties": {
          "enabled": { "type": "boolean" },
          "name": { "type": "string", "minLength": 1 },
          "serviceName": { "type": "string", "minLength": 1 },
          "replicaCount": { "type": "integer", "minimum": 0 },
          "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "image": {
            "type": "object",
            "required": ["repository", "tag"],
            "properties": {
              "repository": { "type": "string", "minLength": 1 },
              "tag": { "type": "string", "minLength": 1 },
              "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
            }
          },
          "service": {
            "type": "object",
            "required": ["port"],
            "properties": {
              "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          },
          "autoscaling": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "minReplicas": { "type": "integer", "minimum": 1 },
              "maxReplicas": { "type": "integer", "minimum": 1 },
              "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          },
          "podSecurityContext": { "$ref": "#/properties/podSecurityContext" },
          "containerSecurityContext": { "$ref": "#/properties/containerSecurityContext" }
        }
      }
    }
  }
}
