{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tradeops.local/schemas/events/surveillance/surveillance.rule_simulation.completed.v1.json",
  "title": "surveillance.rule_simulation.completed v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventType", "eventVersion", "tenantId", "ruleName", "lookbackMinutes", "dryRun", "matchedEvents", "wouldTriggerAlerts", "status", "occurredAt"],
  "properties": {
    "eventId": { "type": "string" },
    "eventType": { "type": "string", "enum": ["surveillance.rule_simulation.completed"] },
    "eventVersion": { "type": "string" },
    "tenantId": { "type": "string" },
    "correlationId": { "type": "string" },
    "traceparent": { "type": "string" },
    "ruleName": { "type": "string" },
    "lookbackMinutes": { "type": "integer", "minimum": 1 },
    "dryRun": { "type": "boolean" },
    "matchedEvents": { "type": "integer", "minimum": 0 },
    "wouldTriggerAlerts": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["completed"] },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
